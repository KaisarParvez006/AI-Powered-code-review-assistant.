{
  "name": "codexa",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev --prefix frontend\" \"npm run dev:api\"",
    "dev:api": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "install:all": "npm install && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
